---
export interface Props {
  lang?: string;
}

const { lang = "ar" } = Astro.props;
const isRTL = lang === "ar";
---

<div class="modern-controls glass-panel">
  <div class="controls-grid">
    <!-- Primary Controls Row -->
    <div class="primary-controls">
      <button
        class="control-btn-modern btn-refresh"
        id="modernRefresh"
        title={isRTL ? "تحديث البث" : "Refresh Stream"}
        aria-label={isRTL ? "تحديث البث" : "Refresh Stream"}
      >
        <div class="btn-icon-wrapper">
          <svg viewBox="0 0 24 24" width="24" height="24">
            <path
              d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
              fill="currentColor"
            />
          </svg>
        </div>
        <span class="btn-text">{isRTL ? "تحديث" : "Refresh"}</span>
        <div class="btn-bg-effect"></div>
      </button>

      <button
        class="control-btn-modern btn-play-stop"
        id="modernPlayStop"
        title={isRTL ? "تشغيل/إيقاف" : "Play/Stop"}
        aria-label={isRTL ? "تشغيل/إيقاف" : "Play/Stop"}
        data-state="stopped"
      >
        <div class="btn-icon-wrapper">
          <svg class="icon-play" viewBox="0 0 24 24" width="32" height="32">
            <path d="M8 5v14l11-7z" fill="currentColor"/>
          </svg>
          <svg class="icon-stop" viewBox="0 0 24 24" width="32" height="32" style="display: none;">
            <rect x="6" y="6" width="12" height="12" fill="currentColor"/>
          </svg>
        </div>
        <span class="btn-text play-text">{isRTL ? "تشغيل" : "Play"}</span>
        <span class="btn-text stop-text" style="display: none;">{isRTL ? "إيقاف" : "Stop"}</span>
        <div class="btn-bg-effect"></div>
        <div class="ripple-container"></div>
      </button>

      <button
        class="control-btn-modern btn-share"
        id="modernShare"
        title={isRTL ? "مشاركة" : "Share"}
        aria-label={isRTL ? "مشاركة" : "Share"}
      >
        <div class="btn-icon-wrapper">
          <svg viewBox="0 0 24 24" width="24" height="24">
            <path
              d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"
              fill="currentColor"
            />
          </svg>
        </div>
        <span class="btn-text">{isRTL ? "مشاركة" : "Share"}</span>
        <div class="btn-bg-effect"></div>
      </button>
    </div>
  </div>
</div>

<style>
  /* Modern Controls Container */
  .modern-controls {
    padding: var(--space-xl);
    background: linear-gradient(
      135deg,
      var(--glass-bg-2) 0%,
      var(--glass-bg-3) 100%
    );
  }

  .controls-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  /* Primary Controls */
  .primary-controls {
    display: flex;
    gap: var(--space-lg);
    justify-content: center;
    align-items: center;
  }

  /* Modern Control Button */
  .control-btn-modern {
    position: relative;
    min-width: 90px;
    height: 90px;
    background: linear-gradient(
      145deg,
      var(--glass-bg-3),
      var(--glass-bg-2)
    );
    backdrop-filter: blur(10px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    color: var(--text-primary);
    cursor: pointer;
    transition: all 0.3s var(--ease-spring);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    overflow: hidden;
    padding: var(--space-md);
    -webkit-tap-highlight-color: transparent;
  }

  .control-btn-modern:hover {
    transform: translateY(-4px) scale(1.05);
    border-color: var(--primary-color);
    box-shadow:
      0 10px 40px rgba(34, 197, 94, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .control-btn-modern:active {
    transform: translateY(-2px) scale(0.98);
    transition: transform 0.1s ease;
  }

  /* Play/Stop Button - Primary */
  .btn-play-stop {
    width: 110px;
    height: 110px;
    background: linear-gradient(
      135deg,
      rgba(34, 197, 94, 0.15),
      rgba(34, 197, 94, 0.05)
    );
    border-color: rgba(34, 197, 94, 0.3);
  }

  .btn-play-stop:hover {
    background: linear-gradient(
      135deg,
      rgba(34, 197, 94, 0.25),
      rgba(34, 197, 94, 0.1)
    );
    box-shadow:
      0 12px 48px rgba(34, 197, 94, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .btn-play-stop[data-state="playing"] {
    animation: pulse-playing 2s ease-in-out infinite;
  }

  @keyframes pulse-playing {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4);
    }
    50% {
      box-shadow: 0 0 0 20px rgba(34, 197, 94, 0);
    }
  }

  /* Icon Wrapper */
  .btn-icon-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s var(--ease-spring);
  }

  .control-btn-modern:hover .btn-icon-wrapper {
    transform: scale(1.1);
  }

  /* Button Text */
  .btn-text {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.9;
    transition: all 0.2s ease;
  }

  .control-btn-modern:hover .btn-text {
    opacity: 1;
    color: var(--primary-color);
  }

  /* Background Effect */
  .btn-bg-effect {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at center,
      var(--primary-glow) 0%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .control-btn-modern:hover .btn-bg-effect {
    opacity: 0.3;
  }

  /* Ripple Effect Container */
  .ripple-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: inherit;
    pointer-events: none;
  }

  .ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    transform: scale(0);
    animation: ripple-animation 0.6s ease-out;
    pointer-events: none;
  }

  @keyframes ripple-animation {
    to {
      transform: scale(4);
      opacity: 0;
    }
  }

  /* Refresh Button Animation */
  .btn-refresh[data-refreshing="true"] .btn-icon-wrapper svg {
    animation: rotate 1s linear infinite;
  }

  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Secondary Controls */
  .secondary-controls {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    align-items: center;
  }

  /* Mini Control Buttons */
  .mini-control-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--glass-bg-2);
    border: 1px solid var(--glass-border);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .mini-control-btn:hover {
    background: var(--glass-bg-3);
    color: var(--primary-color);
    border-color: var(--primary-color);
    transform: scale(1.1);
  }

  .mini-control-btn:active {
    transform: scale(0.95);
  }

  .mini-control-btn[data-active="true"] {
    color: var(--primary-color);
    background: rgba(34, 197, 94, 0.1);
    border-color: var(--primary-color);
  }

  /* Responsive Design */
  @media (max-width: 480px) {
    .primary-controls {
      gap: var(--space-md);
    }

    .control-btn-modern {
      min-width: 75px;
      height: 75px;
      padding: var(--space-sm);
    }

    .btn-play-stop {
      width: 90px;
      height: 90px;
    }

    .btn-text {
      font-size: 0.7rem;
    }

    .mini-control-btn {
      width: 38px;
      height: 38px;
    }

    .mini-control-btn svg {
      width: 18px;
      height: 18px;
    }
  }

  /* Touch Device Optimizations */
  @media (pointer: coarse) {
    .control-btn-modern {
      min-width: 85px;
      min-height: 85px;
    }

    .mini-control-btn {
      min-width: 44px;
      min-height: 44px;
    }
  }
</style>

<script>
  class ModernControls {
    playStopBtn: HTMLElement;
    refreshBtn: HTMLElement;
    shareBtn: HTMLElement;
    audio: HTMLAudioElement | null;
    isPlaying: boolean = false;

    constructor() {
      this.initElements();
      this.initEventListeners();
      this.initRippleEffect();
    }

    initElements() {
      this.playStopBtn = document.getElementById('modernPlayStop')!;
      this.refreshBtn = document.getElementById('modernRefresh')!;
      this.shareBtn = document.getElementById('modernShare')!;

      // Try to find audio element (from any player component)
      this.audio = document.querySelector('audio');
    }

    initEventListeners() {
      // Play/Stop button
      this.playStopBtn.addEventListener('click', () => this.togglePlayStop());

      // Refresh button
      this.refreshBtn.addEventListener('click', () => this.refreshStream());

      // Share button
      this.shareBtn.addEventListener('click', () => this.shareRadio());

      // Listen to audio events if available
      if (this.audio) {
        this.audio.addEventListener('play', () => this.onAudioPlay());
        this.audio.addEventListener('pause', () => this.onAudioStop());
      }
    }

    initRippleEffect() {
      // Add ripple effect to play/stop button
      this.playStopBtn.addEventListener('click', (e) => {
        const rippleContainer = this.playStopBtn.querySelector('.ripple-container');
        if (!rippleContainer) return;

        const ripple = document.createElement('div');
        ripple.className = 'ripple';
        const rect = this.playStopBtn.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height);
        const x = e.clientX - rect.left - size / 2;
        const y = e.clientY - rect.top - size / 2;

        ripple.style.width = ripple.style.height = size + 'px';
        ripple.style.left = x + 'px';
        ripple.style.top = y + 'px';

        rippleContainer.appendChild(ripple);

        setTimeout(() => ripple.remove(), 600);
      });
    }

    togglePlayStop() {
      if (!this.audio) return;

      if (this.isPlaying) {
        this.audio.pause();
      } else {
        this.audio.play();
      }
    }

    onAudioPlay() {
      this.isPlaying = true;
      this.playStopBtn.setAttribute('data-state', 'playing');

      const playIcon = this.playStopBtn.querySelector('.icon-play') as HTMLElement;
      const stopIcon = this.playStopBtn.querySelector('.icon-stop') as HTMLElement;
      const playText = this.playStopBtn.querySelector('.play-text') as HTMLElement;
      const stopText = this.playStopBtn.querySelector('.stop-text') as HTMLElement;

      if (playIcon) playIcon.style.display = 'none';
      if (stopIcon) stopIcon.style.display = 'block';
      if (playText) playText.style.display = 'none';
      if (stopText) stopText.style.display = 'block';
    }

    onAudioStop() {
      this.isPlaying = false;
      this.playStopBtn.setAttribute('data-state', 'stopped');

      const playIcon = this.playStopBtn.querySelector('.icon-play') as HTMLElement;
      const stopIcon = this.playStopBtn.querySelector('.icon-stop') as HTMLElement;
      const playText = this.playStopBtn.querySelector('.play-text') as HTMLElement;
      const stopText = this.playStopBtn.querySelector('.stop-text') as HTMLElement;

      if (playIcon) playIcon.style.display = 'block';
      if (stopIcon) stopIcon.style.display = 'none';
      if (playText) playText.style.display = 'block';
      if (stopText) stopText.style.display = 'none';
    }

    refreshStream() {
      this.refreshBtn.setAttribute('data-refreshing', 'true');

      if (this.audio) {
        const wasPlaying = !this.audio.paused;
        this.audio.load();

        if (wasPlaying) {
          this.audio.play();
        }
      }

      setTimeout(() => {
        this.refreshBtn.removeAttribute('data-refreshing');
      }, 1000);
    }

    shareRadio() {
      if (navigator.share) {
        navigator.share({
          title: 'Holy Quran Radio - Cairo',
          text: 'Listen to live Quran recitation from Cairo',
          url: window.location.href
        }).catch(() => {
          // User cancelled or error
        });
      } else {
        // Fallback - copy to clipboard
        navigator.clipboard.writeText(window.location.href);
        // You could show a toast notification here
      }
    }
  }

  // Initialize controls when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    new ModernControls();
  });
</script>