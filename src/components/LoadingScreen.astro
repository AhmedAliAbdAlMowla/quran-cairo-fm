---
export interface Props {
  lang?: string;
}

const { lang = "ar" } = Astro.props;
const isRTL = lang === "ar";
---

<div class="loading-screen" id="loadingScreen">
  <div class="loading-content">
    <!-- Logo Animation -->
    <div class="loading-logo">
      <div class="logo-wrapper">
        <img src="/images/mosque.png" alt="Logo" class="logo-img" />
        <div class="logo-glow"></div>
        <div class="logo-rings">
          <span class="ring ring-1"></span>
          <span class="ring ring-2"></span>
          <span class="ring ring-3"></span>
        </div>
      </div>
    </div>

    <!-- Loading Text -->
    <div class="loading-text">
      <h2 class="loading-title">
        {isRTL ? "إذاعة القرآن الكريم" : "Holy Quran Radio"}
      </h2>
      <p class="loading-subtitle">
        {isRTL ? "جاري التحميل..." : "Loading..."}
      </p>
    </div>

    <!-- Progress Bar -->
    <div class="loading-progress">
      <div class="progress-bar">
        <div class="progress-fill"></div>
        <div class="progress-glow"></div>
      </div>
      <div class="progress-percentage">0%</div>
    </div>

    <!-- Loading Dots -->
    <div class="loading-dots">
      <span class="dot dot-1"></span>
      <span class="dot dot-2"></span>
      <span class="dot dot-3"></span>
    </div>
  </div>

  <!-- Background Effects -->
  <div class="loading-bg">
    <div class="bg-gradient"></div>
    <div class="bg-pattern"></div>
  </div>
</div>

<!-- Skeleton Loaders for Content -->
<div class="skeleton-container" id="skeletonContainer" style="display: none;">
  <!-- Header Skeleton -->
  <div class="skeleton-panel skeleton-header">
    <div class="skeleton skeleton-logo"></div>
    <div class="skeleton skeleton-title"></div>
    <div class="skeleton skeleton-subtitle"></div>
  </div>

  <!-- Player Skeleton -->
  <div class="skeleton-panel skeleton-player">
    <div class="skeleton skeleton-circle"></div>
    <div class="skeleton-controls">
      <div class="skeleton skeleton-button"></div>
      <div class="skeleton skeleton-button"></div>
      <div class="skeleton skeleton-button"></div>
    </div>
  </div>

  <!-- Controls Skeleton -->
  <div class="skeleton-panel skeleton-controls">
    <div class="skeleton skeleton-button-large"></div>
    <div class="skeleton skeleton-button-large"></div>
    <div class="skeleton skeleton-button-large"></div>
  </div>
</div>

<style>
  /* Loading Screen */
  .loading-screen {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-primary);
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }

  .loading-screen.fade-out {
    opacity: 0;
    visibility: hidden;
  }

  /* Loading Content */
  .loading-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    padding: var(--space-2xl);
    max-width: 400px;
    width: 100%;
  }

  /* Logo Animation */
  .loading-logo {
    position: relative;
    width: 120px;
    height: 120px;
  }

  .logo-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-img {
    width: 80px;
    height: 80px;
    position: relative;
    z-index: 2;
    animation: logo-float 3s ease-in-out infinite;
  }

  @keyframes logo-float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  .logo-glow {
    position: absolute;
    inset: 20%;
    background: radial-gradient(circle, var(--primary-glow) 0%, transparent 70%);
    filter: blur(20px);
    animation: glow-pulse 2s ease-in-out infinite;
  }

  @keyframes glow-pulse {
    0%, 100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.2);
    }
  }

  /* Logo Rings */
  .logo-rings {
    position: absolute;
    inset: 0;
  }

  .ring {
    position: absolute;
    inset: 0;
    border: 1px solid var(--primary-color);
    border-radius: 50%;
    opacity: 0;
    animation: ring-expand 3s ease-out infinite;
  }

  .ring-1 {
    animation-delay: 0s;
  }

  .ring-2 {
    animation-delay: 1s;
  }

  .ring-3 {
    animation-delay: 2s;
  }

  @keyframes ring-expand {
    0% {
      transform: scale(0.8);
      opacity: 1;
    }
    100% {
      transform: scale(2);
      opacity: 0;
    }
  }

  /* Loading Text */
  .loading-text {
    text-align: center;
  }

  .loading-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
    opacity: 0;
    animation: fade-in-up 0.6s ease forwards;
    animation-delay: 0.3s;
  }

  .loading-subtitle {
    font-size: 0.875rem;
    color: var(--text-secondary);
    opacity: 0;
    animation: fade-in-up 0.6s ease forwards;
    animation-delay: 0.4s;
  }

  @keyframes fade-in-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
    from {
      opacity: 0;
      transform: translateY(20px);
    }
  }

  /* Progress Bar */
  .loading-progress {
    width: 100%;
    max-width: 200px;
    opacity: 0;
    animation: fade-in 0.6s ease forwards;
    animation-delay: 0.5s;
  }

  .progress-bar {
    height: 4px;
    background: var(--glass-bg-4);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
    border-radius: 2px;
    width: 0%;
    transition: width 0.3s ease;
    animation: progress-animation 2s ease forwards;
  }

  @keyframes progress-animation {
    to {
      width: 100%;
    }
  }

  .progress-glow {
    position: absolute;
    top: 0;
    right: 0;
    width: 30%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(333%);
    }
  }

  .progress-percentage {
    text-align: center;
    margin-top: var(--space-sm);
    font-size: 0.75rem;
    color: var(--text-secondary);
    font-weight: 600;
  }

  /* Loading Dots */
  .loading-dots {
    display: flex;
    gap: var(--space-sm);
    opacity: 0;
    animation: fade-in 0.6s ease forwards;
    animation-delay: 0.6s;
  }

  .dot {
    width: 8px;
    height: 8px;
    background: var(--primary-color);
    border-radius: 50%;
    animation: dot-bounce 1.4s ease-in-out infinite;
  }

  .dot-1 {
    animation-delay: 0s;
  }

  .dot-2 {
    animation-delay: 0.2s;
  }

  .dot-3 {
    animation-delay: 0.4s;
  }

  @keyframes dot-bounce {
    0%, 80%, 100% {
      transform: translateY(0);
      opacity: 1;
    }
    40% {
      transform: translateY(-10px);
      opacity: 0.7;
    }
  }

  /* Background Effects */
  .loading-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .bg-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at center,
      rgba(34, 197, 94, 0.1) 0%,
      transparent 70%
    );
    animation: gradient-rotate 10s linear infinite;
  }

  @keyframes gradient-rotate {
    to {
      transform: rotate(360deg);
    }
  }

  .bg-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 35px,
      var(--glass-border) 35px,
      var(--glass-border) 70px
    );
  }

  /* Skeleton Loader Styles */
  .skeleton-container {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg);
    gap: var(--space-lg);
    max-width: 560px;
    margin: 0 auto;
  }

  .skeleton-panel {
    width: 100%;
    background: var(--glass-bg-2);
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
  }

  .skeleton {
    background: linear-gradient(
      90deg,
      var(--glass-bg-3) 0%,
      var(--glass-bg-4) 50%,
      var(--glass-bg-3) 100%
    );
    background-size: 200% 100%;
    animation: skeleton-loading 1.5s ease-in-out infinite;
    border-radius: var(--radius-md);
  }

  @keyframes skeleton-loading {
    0% {
      background-position: -100% 0;
    }
    100% {
      background-position: 100% 0;
    }
  }

  .skeleton-logo {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    margin: 0 auto var(--space-md);
  }

  .skeleton-title {
    height: 24px;
    width: 60%;
    margin: 0 auto var(--space-sm);
  }

  .skeleton-subtitle {
    height: 16px;
    width: 40%;
    margin: 0 auto;
  }

  .skeleton-circle {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    margin: 0 auto var(--space-lg);
  }

  .skeleton-controls {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
  }

  .skeleton-button {
    width: 60px;
    height: 60px;
    border-radius: var(--radius-lg);
  }

  .skeleton-button-large {
    width: 90px;
    height: 90px;
    border-radius: var(--radius-lg);
    display: inline-block;
    margin: 0 var(--space-sm);
  }

  /* Responsive */
  @media (max-width: 480px) {
    .loading-logo {
      width: 100px;
      height: 100px;
    }

    .logo-img {
      width: 60px;
      height: 60px;
    }

    .loading-title {
      font-size: 1.25rem;
    }

    .skeleton-circle {
      width: 140px;
      height: 140px;
    }
  }

  @keyframes fade-in {
    to {
      opacity: 1;
    }
    from {
      opacity: 0;
    }
  }
</style>

<script>
  class LoadingManager {
    private loadingScreen: HTMLElement;
    private skeletonContainer: HTMLElement;
    private progressFill: HTMLElement;
    private progressPercentage: HTMLElement;
    private startTime: number;
    private progress: number = 0;

    constructor() {
      this.loadingScreen = document.getElementById('loadingScreen')!;
      this.skeletonContainer = document.getElementById('skeletonContainer')!;
      this.progressFill = document.querySelector('.progress-fill')!;
      this.progressPercentage = document.querySelector('.progress-percentage')!;
      this.startTime = Date.now();
      this.init();
    }

    private init() {
      this.simulateLoading();
      this.trackActualLoading();
    }

    private simulateLoading() {
      const duration = 2000; // 2 seconds
      const interval = 50; // Update every 50ms
      const steps = duration / interval;
      const increment = 100 / steps;

      const timer = setInterval(() => {
        this.progress += increment;
        if (this.progress >= 100) {
          this.progress = 100;
          clearInterval(timer);
          this.onLoadingComplete();
        }
        this.updateProgress();
      }, interval);
    }

    private updateProgress() {
      const rounded = Math.round(this.progress);
      this.progressPercentage.textContent = `${rounded}%`;
      // Progress fill is animated via CSS
    }

    private trackActualLoading() {
      // Wait for all critical resources
      Promise.all([
        this.waitForDOMContent(),
        this.waitForImages(),
        this.waitForFonts(),
        this.ensureMinimumLoadTime()
      ]).then(() => {
        this.onLoadingComplete();
      });
    }

    private waitForDOMContent(): Promise<void> {
      return new Promise(resolve => {
        if (document.readyState === 'complete') {
          resolve();
        } else {
          window.addEventListener('load', () => resolve());
        }
      });
    }

    private waitForImages(): Promise<void> {
      const images = Array.from(document.images);
      const promises = images.map(img => {
        return new Promise<void>((resolve) => {
          if (img.complete) {
            resolve();
          } else {
            img.addEventListener('load', () => resolve());
            img.addEventListener('error', () => resolve()); // Resolve even on error
          }
        });
      });
      return Promise.all(promises).then(() => {});
    }

    private waitForFonts(): Promise<void> {
      if ('fonts' in document) {
        return (document as any).fonts.ready;
      }
      return Promise.resolve();
    }

    private ensureMinimumLoadTime(): Promise<void> {
      const minLoadTime = 1500; // Minimum 1.5 seconds
      const elapsed = Date.now() - this.startTime;
      const remaining = Math.max(0, minLoadTime - elapsed);
      return new Promise(resolve => setTimeout(resolve, remaining));
    }

    private onLoadingComplete() {
      // Ensure progress is 100%
      this.progress = 100;
      this.updateProgress();

      // Fade out loading screen
      setTimeout(() => {
        this.loadingScreen.classList.add('fade-out');

        // Remove from DOM after animation
        setTimeout(() => {
          this.loadingScreen.style.display = 'none';
          this.showContent();
        }, 500);
      }, 300);
    }

    private showContent() {
      // Directly show content without skeleton phase
      // This eliminates the flash of empty skeleton loaders
      document.body.classList.add('content-loaded');
    }

    // Public method to show skeleton for specific sections
    public showSkeleton(section?: string) {
      this.skeletonContainer.style.display = 'flex';

      // Hide specific skeleton sections if needed
      if (section) {
        const otherSections = this.skeletonContainer.querySelectorAll(
          `.skeleton-panel:not(.skeleton-${section})`
        );
        otherSections.forEach(el => {
          (el as HTMLElement).style.display = 'none';
        });
      }
    }

    public hideSkeleton() {
      this.skeletonContainer.style.display = 'none';
    }
  }

  // Initialize loading manager
  const loadingManager = new LoadingManager();

  // Export for use in other scripts
  (window as any).loadingManager = loadingManager;
</script>