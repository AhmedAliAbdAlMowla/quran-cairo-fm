---
import { translations } from '../config/translations';

export interface Props {
  lang?: 'ar' | 'en';
}

const { lang = 'ar' } = Astro.props;
const t = translations[lang];
const isRTL = lang === 'ar';
---

<div class="radio-container">
  <!-- Header -->
  <div class="glass-panel header-panel">
    <div class="water-ripple"></div>
    <h1 class="glass-title">
      <img src="/images/mosque.png" alt={isRTL ? "رمز إسلامي" : "Islamic Icon"} class="icon-glow" />
      <span class="title-text">
        {isRTL ? 'إذاعة القرآن الكريم' : 'Holy Quran Radio'}
      </span>
    </h1>
    <p class="subtitle">
      {isRTL ? 'من القاهرة • مصر' : 'From Cairo • Egypt'}
    </p>
  </div>

  <!-- Player -->
  <div class="glass-panel player-panel">
    <div class="water-animation">
      <div class="water-wave wave-1"></div>
      <div class="water-wave wave-2"></div>
      <div class="water-wave wave-3"></div>
    </div>

    <div class="player-container">
      <audio id="egyptAudio">
        <source src="https://n01.radiojar.com/8s5u5tpdtwzuv?rj-ttl=5&rj-tok=AAABmXK3CA0AlLPRdfTei-KzcQ" type="audio/mpeg" />
        <source src="https://n06.radiojar.com/8s5u5tpdtwzuv?rj-ttl=5&rj-tok=AAABmXITLbUAnkhYRNoalMnuuw" type="audio/mpeg" />
      </audio>

      <div class="custom-player">
        <div class="counter-display">
          <div class="counter-label" id="counterLabel">{t.ready}</div>
          <div class="counter-time">
            <span id="currentTime" class="time-digit">00</span>
            <span class="time-separator">:</span>
            <span id="currentSeconds" class="time-digit">00</span>
          </div>
          <div class="live-indicator">
            <span class="live-dot"></span>
            <span class="live-text">{t.live}</span>
          </div>
        </div>
      </div>

      <!-- Volume Control -->
      <div class="volume-control">
        <div class="volume-icon">🔊</div>
        <div class="volume-slider-container">
          <input type="range" id="volumeSlider" class="volume-slider" min="0" max="100" value="80" />
          <div class="volume-fill"></div>
        </div>
        <div class="volume-value">80%</div>
      </div>
    </div>
  </div>

  <!-- Controls -->
  <div class="glass-panel controls-panel">
    <div class="controls-wrapper">
      <button class="control-btn play-btn" data-action="play" title={t.play}>
        <svg class="btn-svg" viewBox="0 0 24 24" width="24" height="24">
          <path d="M8 5v14l11-7z" fill="currentColor"></path>
        </svg>
        <span class="btn-label">{t.play}</span>
        <span class="btn-ripple"></span>
      </button>

      <button class="control-btn stop-btn" data-action="stop" title={t.stop}>
        <svg class="btn-svg" viewBox="0 0 24 24" width="24" height="24">
          <rect x="6" y="6" width="12" height="12" fill="currentColor"></rect>
        </svg>
        <span class="btn-label">{t.stop}</span>
        <span class="btn-ripple"></span>
      </button>

      <button class="control-btn refresh-btn" data-action="refresh" title={t.refresh}>
        <svg class="btn-svg rotating" viewBox="0 0 24 24" width="24" height="24">
          <path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" fill="currentColor"></path>
        </svg>
        <span class="btn-label">{t.refresh}</span>
        <span class="btn-ripple"></span>
      </button>
    </div>
  </div>

  <!-- Status -->
  <div class="glass-panel status-panel">
    <div class="status-indicator">
      <span class="pulse-dot"></span>
      <span id="status" class="status-text">{t.ready}</span>
    </div>
  </div>
</div>

<script define:vars={{ lang, t }}>
  // RadioPlayer class encapsulating all functionality
  class RadioPlayer {
    constructor() {
      this.audio = null;
      this.elements = {};
      this.state = {
        playbackTime: 0,
        counterInterval: null,
        loadingTimeout: null,
        isIOS: /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream
      };
      this.translations = t;
      this.init();
    }

    init() {
      // Wait for DOM to be ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => this.setup());
      } else {
        this.setup();
      }
    }

    setup() {
      this.initElements();
      if (this.audio && this.elements.status) {
        this.attachEventListeners();
        this.updateStatus('ready');
      } else {
        // Retry after a short delay (for hydration)
        setTimeout(() => {
          this.initElements();
          if (this.audio && this.elements.status) {
            this.attachEventListeners();
            this.updateStatus('ready');
          }
        }, 500);
      }
    }

    initElements() {
      this.audio = document.getElementById('egyptAudio');
      this.elements = {
        status: document.getElementById('status'),
        statusIndicator: document.querySelector('.status-indicator'),
        playerPanel: document.querySelector('.player-panel'),
        volumeSlider: document.getElementById('volumeSlider'),
        volumeValue: document.querySelector('.volume-value'),
        volumeFill: document.querySelector('.volume-fill'),
        volumeIcon: document.querySelector('.volume-icon'),
        currentTime: document.getElementById('currentTime'),
        currentSeconds: document.getElementById('currentSeconds'),
        liveIndicator: document.querySelector('.live-indicator'),
        counterLabel: document.getElementById('counterLabel')
      };
    }

    attachEventListeners() {
      // Control buttons
      document.querySelectorAll('[data-action]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const action = e.currentTarget.dataset.action;
          this[action + 'Radio']?.();
        });
      });

      // Audio events
      if (this.audio) {
        this.audio.addEventListener('loadstart', () => this.onLoadStart());
        this.audio.addEventListener('canplay', () => this.onCanPlay());
        this.audio.addEventListener('play', () => this.onPlay());
        this.audio.addEventListener('pause', () => this.onPause());
        this.audio.addEventListener('ended', () => this.onEnded());
        this.audio.addEventListener('error', () => this.onError());
      }

      // Volume control
      if (this.elements.volumeSlider) {
        this.elements.volumeSlider.addEventListener('input', () => this.updateVolume());
        this.elements.volumeSlider.addEventListener('change', () => this.updateVolume());
        this.updateVolume();
      }

      // Initialize volume for non-iOS
      if (!this.state.isIOS && this.audio) {
        this.audio.volume = 0.8;
      }

      // Viewport height for mobile
      this.setViewportHeight();
      window.addEventListener('resize', () => this.setViewportHeight());
      window.addEventListener('orientationchange', () => this.setViewportHeight());

      // Touch handling
      this.setupTouchHandlers();
    }

    playRadio() {
      if (!this.audio) return;

      const playPromise = this.audio.play();
      if (playPromise !== undefined) {
        playPromise.then(() => {
          this.updateStatus('playing');
          this.animateButton('play');
        }).catch(error => {
          console.error('Playback error:', error);
          this.elements.status.textContent = this.translations.pressAgain;
          setTimeout(() => {
            this.elements.status.textContent = this.translations.ready;
          }, 2000);
        });
      }
    }

    stopRadio() {
      if (!this.audio) return;
      this.audio.pause();
      this.audio.currentTime = 0;
      this.updateStatus('stopped');
      this.animateButton('stop');
    }

    refreshRadio() {
      if (!this.audio) return;
      this.updateStatus('refreshing');
      this.animateButton('refresh');
      this.audio.load();

      setTimeout(() => {
        const playPromise = this.audio.play();
        if (playPromise !== undefined) {
          playPromise.then(() => {
            this.updateStatus('playing');
          }).catch(error => {
            console.error('Refresh error:', error);
            this.elements.status.textContent = this.translations.ready;
          });
        }
      }, 1000);
    }

    updateStatus(state) {
      if (!this.elements.status || !this.elements.statusIndicator) return;

      const states = {
        playing: { text: this.translations.playing, class: 'playing' },
        paused: { text: this.translations.paused, class: '' },
        stopped: { text: this.translations.stopped, class: '' },
        refreshing: { text: this.translations.refreshing, class: '' },
        ready: { text: this.translations.ready, class: '' }
      };

      const config = states[state] || states.ready;
      this.elements.status.textContent = config.text;

      if (config.class) {
        this.elements.statusIndicator.classList.add(config.class);
      } else {
        this.elements.statusIndicator.classList.remove('playing');
      }

      if (this.elements.playerPanel) {
        if (state === 'playing') {
          this.elements.playerPanel.classList.add('playing');
        } else {
          this.elements.playerPanel.classList.remove('playing');
        }
      }
    }

    animateButton(action) {
      const btn = document.querySelector(`.${action}-btn`);
      if (btn) {
        if (action === 'play') {
          btn.classList.add('playing');
        } else if (action === 'stop') {
          document.querySelector('.play-btn')?.classList.remove('playing');
        } else if (action === 'refresh') {
          const svg = btn.querySelector('.btn-svg');
          if (svg) {
            svg.style.animation = 'rotate-icon 1s ease-in-out';
            setTimeout(() => { svg.style.animation = ''; }, 1000);
          }
        }
        this.createRipple(btn);
      }
    }

    createRipple(button) {
      const ripple = button.querySelector('.btn-ripple');
      if (!ripple) return;

      ripple.style.display = 'block';
      ripple.style.animation = 'ripple-effect 0.6s ease-out';
      setTimeout(() => {
        ripple.style.display = 'none';
        ripple.style.animation = '';
      }, 600);
    }

    updateVolume() {
      if (!this.elements.volumeSlider) return;

      const value = this.elements.volumeSlider.value;

      if (!this.state.isIOS && this.audio) {
        this.audio.volume = value / 100;
      }

      if (this.elements.volumeValue) {
        this.elements.volumeValue.textContent = value + '%';
      }

      if (this.elements.volumeFill) {
        this.elements.volumeFill.style.height = value + '%';
      }

      if (this.elements.volumeIcon) {
        this.elements.volumeIcon.textContent =
          value == 0 ? '🔇' :
          value < 33 ? '🔈' :
          value < 66 ? '🔉' : '🔊';
      }
    }

    startCounter() {
      this.state.playbackTime = 0;
      clearInterval(this.state.counterInterval);
      this.state.counterInterval = setInterval(() => {
        this.state.playbackTime++;
        this.updateCounter();
      }, 1000);
    }

    stopCounter() {
      clearInterval(this.state.counterInterval);
      this.state.playbackTime = 0;
      this.updateCounter();
    }

    updateCounter() {
      if (!this.elements.currentTime || !this.elements.currentSeconds) return;

      const mins = Math.floor(this.state.playbackTime / 60);
      const secs = this.state.playbackTime % 60;
      this.elements.currentTime.textContent = mins.toString().padStart(2, '0');
      this.elements.currentSeconds.textContent = secs.toString().padStart(2, '0');
    }

    setViewportHeight() {
      const vh = window.innerHeight * 0.01;
      document.documentElement.style.setProperty('--vh', `${vh}px`);
    }

    setupTouchHandlers() {
      document.querySelectorAll('.control-btn').forEach(button => {
        button.addEventListener('touchstart', function(e) {
          e.preventDefault();
          this.classList.add('touch-active');
        });
        button.addEventListener('touchend', function(e) {
          e.preventDefault();
          this.classList.remove('touch-active');
        });
      });
    }

    // Event handlers
    onLoadStart() {
      if (this.elements.status) this.elements.status.textContent = this.translations.loading;
      if (this.elements.counterLabel) this.elements.counterLabel.textContent = this.translations.loading;

      clearTimeout(this.state.loadingTimeout);
      this.state.loadingTimeout = setTimeout(() => {
        if (this.audio.paused) {
          if (this.elements.status) this.elements.status.textContent = this.translations.ready;
          if (this.elements.counterLabel) this.elements.counterLabel.textContent = this.translations.ready;
        }
      }, 3000);
    }

    onCanPlay() {
      clearTimeout(this.state.loadingTimeout);
      if (!this.audio.paused) {
        this.updateStatus('playing');
      } else {
        if (this.elements.status) this.elements.status.textContent = this.translations.ready;
        if (this.elements.counterLabel) this.elements.counterLabel.textContent = this.translations.ready;
      }
    }

    onPlay() {
      this.updateStatus('playing');
      this.startCounter();
      if (this.elements.liveIndicator) this.elements.liveIndicator.classList.add('active');
      if (this.elements.counterLabel) this.elements.counterLabel.textContent = this.translations.playing;
    }

    onPause() {
      this.updateStatus('paused');
      this.stopCounter();
      if (this.elements.liveIndicator) this.elements.liveIndicator.classList.remove('active');
      if (this.elements.counterLabel) this.elements.counterLabel.textContent = this.translations.paused;
    }

    onEnded() {
      this.updateStatus('stopped');
      this.stopCounter();
      if (this.elements.liveIndicator) this.elements.liveIndicator.classList.remove('active');
      if (this.elements.counterLabel) this.elements.counterLabel.textContent = this.translations.stopped;
    }

    onError() {
      if (this.elements.status) this.elements.status.textContent = this.translations.error;
      if (this.elements.playerPanel) this.elements.playerPanel.classList.remove('playing');
      if (this.elements.counterLabel) this.elements.counterLabel.textContent = this.translations.error;
      if (this.elements.liveIndicator) this.elements.liveIndicator.classList.remove('active');
    }
  }

  // Initialize the radio player
  new RadioPlayer();
</script>