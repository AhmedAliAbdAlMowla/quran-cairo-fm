---
export interface Props {
  currentLang?: 'ar' | 'en';
}

const { currentLang = 'ar' } = Astro.props;

const languages = [
  { code: 'en', label: 'EN', path: '/en' },
  { code: 'ar', label: 'عربي', path: '/' }
];
---

<div class="lang-switcher">
  {languages.map(lang => (
    <a
      href={lang.path}
      class={`lang-btn ${currentLang === lang.code ? 'active' : ''}`}
      aria-label={`Switch to ${lang.code === 'ar' ? 'Arabic' : 'English'}`}
    >
      <span class="lang-text">{lang.label}</span>
    </a>
  ))}
</div>

<style>
  .lang-switcher {
    position: fixed;
    top: 20px;
    right: 20px;
    display: flex;
    gap: 10px;
    z-index: 1000;
  }

  .lang-btn {
    padding: 10px 15px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 10px;
    color: white;
    text-decoration: none;
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .lang-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .lang-btn.active {
    background: linear-gradient(135deg, var(--primary-light), var(--primary-dark));
    border-color: var(--primary-glow);
    box-shadow: 0 0 20px var(--primary-glow);
  }

  .lang-text {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  @media (max-width: 768px) {
    .lang-switcher {
      top: 10px;
      right: 10px;
    }

    .lang-btn {
      padding: 8px 12px;
    }

    .lang-text {
      font-size: 12px;
    }
  }
</style>