---
export interface Props {
  lang?: string;
}

const { lang = "ar" } = Astro.props;
const isRTL = lang === "ar";
---

<div class="modern-player glass-panel" data-player="modern">
  <!-- Background Effects -->
  <div class="player-background">
    <div class="audio-visualizer">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </div>
  </div>

  <!-- Main Player Interface -->
  <div class="player-interface">
    <!-- Circular Progress Player -->
    <div class="circular-player">
      <svg class="progress-ring" width="200" height="200">
        <circle
          class="progress-ring-bg"
          cx="100"
          cy="100"
          r="88"
          fill="none"
          stroke-width="4"
        />
        <circle
          class="progress-ring-fill"
          cx="100"
          cy="100"
          r="88"
          fill="none"
          stroke-width="4"
          stroke-dasharray="553"
          stroke-dashoffset="553"
        />
      </svg>

      <div class="player-controls-center">
        <button class="play-pause-btn" id="modernPlayPause" aria-label={isRTL ? "تشغيل/إيقاف" : "Play/Pause"}>
          <svg class="play-icon" viewBox="0 0 24 24" width="40" height="40">
            <path d="M8 5v14l11-7z" fill="currentColor"/>
          </svg>
          <svg class="pause-icon" viewBox="0 0 24 24" width="40" height="40" style="display: none;">
            <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" fill="currentColor"/>
          </svg>
        </button>

        <div class="time-display">
          <span id="modernTime">00:00</span>
        </div>
      </div>
    </div>

    <!-- Bottom Controls -->
    <div class="player-controls-bottom">
      <!-- Volume Control -->
      <div class="volume-control-modern">
        <button class="volume-btn" id="volumeBtn" aria-label={isRTL ? "الصوت" : "Volume"}>
          <svg class="volume-icon" viewBox="0 0 24 24" width="20" height="20">
            <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z" fill="currentColor"/>
          </svg>
        </button>
        <div class="volume-slider-wrapper">
          <input
            type="range"
            class="volume-slider-modern"
            id="modernVolumeSlider"
            min="0"
            max="100"
            value="80"
            aria-label={isRTL ? "مستوى الصوت" : "Volume Level"}
          />
        </div>
      </div>

      <!-- Sleep Timer -->
      <div class="sleep-timer">
        <button class="timer-btn" id="timerBtn" aria-label={isRTL ? "مؤقت النوم" : "Sleep Timer"}>
          <svg viewBox="0 0 24 24" width="20" height="20">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" fill="currentColor"/>
          </svg>
          <span class="timer-badge" id="timerBadge" style="display: none;"></span>
        </button>
      </div>

      <!-- Quality Indicator -->
      <div class="quality-indicator">
        <span class="quality-badge">HD</span>
      </div>

      <!-- More Options -->
      <button class="more-btn" id="moreBtn" aria-label={isRTL ? "المزيد" : "More"}>
        <svg viewBox="0 0 24 24" width="20" height="20">
          <path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z" fill="currentColor"/>
        </svg>
      </button>
    </div>

    <!-- Live Indicator -->
    <div class="live-badge" id="modernLiveBadge">
      <span class="live-dot-modern"></span>
      <span class="live-text-modern">{isRTL ? "مباشر" : "LIVE"}</span>
    </div>
  </div>

  <!-- Hidden Audio Element -->
  <audio id="modernAudio" preload="none">
    <source
      src="https://n01.radiojar.com/8s5u5tpdtwzuv?rj-ttl=5&rj-tok=AAABmXK3CA0AlLPRdfTei-KzcQ"
      type="audio/mpeg"
    />
    <source
      src="https://n06.radiojar.com/8s5u5tpdtwzuv?rj-ttl=5&rj-tok=AAABmXITLbUAnkhYRNoalMnuuw"
      type="audio/mpeg"
    />
  </audio>
</div>

<!-- Sleep Timer Modal -->
<div class="timer-modal" id="timerModal" style="display: none;">
  <div class="timer-modal-content">
    <div class="timer-modal-header">
      <h3 class="timer-modal-title">{isRTL ? "مؤقت النوم" : "Sleep Timer"}</h3>
      <button class="timer-modal-close" id="timerModalClose" aria-label={isRTL ? "إغلاق" : "Close"}>
        <svg viewBox="0 0 24 24" width="20" height="20">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/>
        </svg>
      </button>
    </div>
    <div class="timer-modal-body">
      <p class="timer-description">{isRTL ? "اختر المدة الزمنية لإيقاف التشغيل تلقائياً" : "Choose duration to stop playback automatically"}</p>
      <div class="timer-options">
        <button class="timer-option" data-minutes="5">
          <span class="timer-option-time">5</span>
          <span class="timer-option-label">{isRTL ? "دقائق" : "min"}</span>
        </button>
        <button class="timer-option" data-minutes="10">
          <span class="timer-option-time">10</span>
          <span class="timer-option-label">{isRTL ? "دقائق" : "min"}</span>
        </button>
        <button class="timer-option" data-minutes="15">
          <span class="timer-option-time">15</span>
          <span class="timer-option-label">{isRTL ? "دقائق" : "min"}</span>
        </button>
        <button class="timer-option" data-minutes="30">
          <span class="timer-option-time">30</span>
          <span class="timer-option-label">{isRTL ? "دقائق" : "min"}</span>
        </button>
        <button class="timer-option" data-minutes="45">
          <span class="timer-option-time">45</span>
          <span class="timer-option-label">{isRTL ? "دقائق" : "min"}</span>
        </button>
        <button class="timer-option" data-minutes="60">
          <span class="timer-option-time">60</span>
          <span class="timer-option-label">{isRTL ? "دقائق" : "min"}</span>
        </button>
      </div>
      <button class="timer-cancel-btn" id="timerCancelBtn">
        <svg viewBox="0 0 24 24" width="18" height="18">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/>
        </svg>
        <span>{isRTL ? "إلغاء المؤقت" : "Cancel Timer"}</span>
      </button>
    </div>
  </div>
</div>

<style>
  /* Modern Player Styles */
  .modern-player {
    position: relative;
    padding: var(--space-2xl);
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .player-background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: var(--radius-xl);
    pointer-events: none;
  }

  /* Audio Visualizer */
  .audio-visualizer {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: flex-end;
    gap: 4px;
    height: 100px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .modern-player.playing .audio-visualizer {
    opacity: 0.3;
  }

  .audio-visualizer .bar {
    width: 4px;
    background: linear-gradient(to top, var(--primary-color), transparent);
    border-radius: 2px;
    animation: audio-wave 1s ease-in-out infinite;
  }

  .audio-visualizer .bar:nth-child(1) { animation-delay: 0s; height: 20%; }
  .audio-visualizer .bar:nth-child(2) { animation-delay: 0.1s; height: 30%; }
  .audio-visualizer .bar:nth-child(3) { animation-delay: 0.2s; height: 45%; }
  .audio-visualizer .bar:nth-child(4) { animation-delay: 0.3s; height: 60%; }
  .audio-visualizer .bar:nth-child(5) { animation-delay: 0.4s; height: 45%; }
  .audio-visualizer .bar:nth-child(6) { animation-delay: 0.5s; height: 30%; }
  .audio-visualizer .bar:nth-child(7) { animation-delay: 0.6s; height: 20%; }
  .audio-visualizer .bar:nth-child(8) { animation-delay: 0.7s; height: 15%; }

  @keyframes audio-wave {
    0%, 100% { transform: scaleY(0.5); }
    50% { transform: scaleY(1); }
  }

  /* Player Interface */
  .player-interface {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 400px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
  }

  /* Track Info */
  .track-info {
    text-align: center;
    animation: fade-in 0.6s ease;
  }

  .track-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
  }

  .track-subtitle {
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Circular Progress Player */
  .circular-player {
    position: relative;
    width: 200px;
    height: 200px;
  }

  .progress-ring {
    transform: rotate(-90deg);
  }

  .progress-ring-bg {
    stroke: var(--glass-bg-4);
  }

  .progress-ring-fill {
    stroke: var(--primary-color);
    transition: stroke-dashoffset 0.3s ease;
    stroke-linecap: round;
  }

  .player-controls-center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
  }

  /* Play/Pause Button */
  .play-pause-btn {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
    border: none;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s var(--ease-spring);
    box-shadow:
      0 4px 20px rgba(34, 197, 94, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .play-pause-btn:hover {
    transform: scale(1.1);
    box-shadow:
      0 6px 30px rgba(34, 197, 94, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }

  .play-pause-btn:active {
    transform: scale(0.95);
  }

  .play-icon, .pause-icon {
    transition: opacity 0.2s ease;
  }

  /* Time Display */
  .time-display {
    font-family: 'Monaco', 'Courier New', monospace;
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  /* Bottom Controls */
  .player-controls-bottom {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-md);
    background: var(--glass-bg-2);
    border-radius: var(--radius-full);
    backdrop-filter: blur(10px);
  }

  /* Volume Control Modern */
  .volume-control-modern {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .volume-btn, .speed-btn, .timer-btn, .more-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .volume-btn:hover, .speed-btn:hover, .timer-btn:hover, .more-btn:hover {
    background: var(--glass-bg-3);
    border-color: var(--primary-color);
    color: var(--primary-color);
  }

  .volume-slider-wrapper {
    width: 0;
    overflow: hidden;
    transition: width 0.3s ease;
  }

  .volume-control-modern:hover .volume-slider-wrapper {
    width: 100px;
  }

  .volume-slider-modern {
    width: 100px;
    height: 4px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--glass-bg-4);
    border-radius: 2px;
    outline: none;
  }

  .volume-slider-modern::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 16px;
    height: 16px;
    background: var(--primary-color);
    border-radius: 50%;
    cursor: pointer;
  }

  .volume-slider-modern::-moz-range-thumb {
    width: 16px;
    height: 16px;
    background: var(--primary-color);
    border-radius: 50%;
    cursor: pointer;
    border: none;
  }

  /* Timer Badge */
  .timer-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    background: var(--primary-color);
    color: white;
    font-size: 0.625rem;
    font-weight: 700;
    padding: 2px 5px;
    border-radius: var(--radius-full);
    min-width: 24px;
    text-align: center;
    box-shadow: 0 2px 8px rgba(34, 197, 94, 0.4);
    animation: pulse-badge 2s ease-in-out infinite;
  }

  @keyframes pulse-badge {
    0%, 100% {
      transform: scale(1);
      box-shadow: 0 2px 8px rgba(34, 197, 94, 0.4);
    }
    50% {
      transform: scale(1.1);
      box-shadow: 0 4px 12px rgba(34, 197, 94, 0.6);
    }
  }

  .timer-btn {
    position: relative;
  }

  .timer-btn[data-active="true"] {
    color: var(--primary-color);
    background: rgba(34, 197, 94, 0.1);
    border-color: var(--primary-color);
  }

  /* Timer Modal */
  .timer-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    z-index: var(--z-modal);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg);
    animation: modal-fade-in 0.3s ease;
  }

  @keyframes modal-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .timer-modal-content {
    background: linear-gradient(
      135deg,
      var(--glass-bg-4) 0%,
      var(--glass-bg-3) 100%
    );
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl);
    max-width: 400px;
    width: 100%;
    box-shadow: var(--shadow-xl);
    animation: modal-slide-up 0.3s var(--ease-spring);
  }

  @keyframes modal-slide-up {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .timer-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-xl);
  }

  .timer-modal-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .timer-modal-close {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .timer-modal-close:hover {
    background: var(--glass-bg-3);
    border-color: var(--primary-color);
    color: var(--primary-color);
    transform: rotate(90deg);
  }

  .timer-modal-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .timer-description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-align: center;
    margin: 0;
  }

  .timer-options {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .timer-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg);
    background: var(--glass-bg-2);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: all 0.2s ease;
    color: var(--text-primary);
  }

  .timer-option:hover {
    background: var(--glass-bg-3);
    border-color: var(--primary-color);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(34, 197, 94, 0.2);
  }

  .timer-option:active {
    transform: translateY(0);
  }

  .timer-option-time {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary-color);
    margin-bottom: var(--space-xs);
  }

  .timer-option-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .timer-cancel-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: var(--radius-lg);
    color: #ef4444;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: var(--space-sm);
  }

  .timer-cancel-btn:hover {
    background: rgba(239, 68, 68, 0.2);
    border-color: #ef4444;
    transform: translateY(-2px);
  }

  .timer-cancel-btn:active {
    transform: translateY(0);
  }

  .timer-cancel-btn[data-hidden="true"] {
    display: none;
  }

  /* Quality Badge */
  .quality-badge {
    padding: 4px 8px;
    background: var(--primary-color);
    color: white;
    border-radius: 4px;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  /* Live Badge */
  .live-badge {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: var(--radius-full);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .modern-player.playing .live-badge {
    opacity: 1;
  }

  .live-dot-modern {
    width: 8px;
    height: 8px;
    background: #ef4444;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .live-text-modern {
    font-size: 0.75rem;
    font-weight: 600;
    color: #ef4444;
    letter-spacing: 0.05em;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.2);
    }
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive */
  @media (max-width: 480px) {
    .modern-player {
      padding: var(--space-lg);
      min-height: 350px;
    }

    .circular-player {
      width: 160px;
      height: 160px;
    }

    .progress-ring {
      width: 160px;
      height: 160px;
    }

    .progress-ring-bg,
    .progress-ring-fill {
      r: 70;
      cx: 80;
      cy: 80;
      stroke-dasharray: 440;
    }

    .play-pause-btn {
      width: 60px;
      height: 60px;
    }

    .play-pause-btn svg {
      width: 30px;
      height: 30px;
    }

    .player-controls-bottom {
      gap: var(--space-md);
      padding: var(--space-sm);
    }

    .volume-btn, .speed-btn, .timer-btn, .more-btn {
      width: 32px;
      height: 32px;
    }

    .timer-modal-content {
      padding: var(--space-lg);
      max-width: 90%;
    }

    .timer-options {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-sm);
    }

    .timer-option {
      padding: var(--space-md);
    }

    .timer-option-time {
      font-size: 1.25rem;
    }
  }
</style>

<script>
  class ModernRadioPlayer {
    audio: HTMLAudioElement;
    playPauseBtn: HTMLElement;
    playIcon: HTMLElement;
    pauseIcon: HTMLElement;
    timeDisplay: HTMLElement;
    volumeSlider: HTMLInputElement;
    progressRing: SVGCircleElement;
    playerContainer: HTMLElement;
    liveBadge: HTMLElement;
    timerBtn: HTMLElement;
    timerModal: HTMLElement;
    timerModalClose: HTMLElement;
    timerCancelBtn: HTMLElement;
    timerBadge: HTMLElement;
    isPlaying: boolean = false;
    playbackTime: number = 0;
    timerInterval: ReturnType<typeof setInterval> | null = null;
    sleepTimer: ReturnType<typeof setTimeout> | null = null;
    sleepTimerCountdown: ReturnType<typeof setInterval> | null = null;
    sleepTimerMinutes: number = 0;
    sleepTimerRemaining: number = 0;
    circumference: number = 2 * Math.PI * 88;

    constructor() {
      this.initElements();
      this.initEventListeners();
      this.initKeyboardShortcuts();
    }

    initElements() {
      this.audio = document.getElementById('modernAudio') as HTMLAudioElement;
      this.playPauseBtn = document.getElementById('modernPlayPause')!;
      this.playIcon = this.playPauseBtn.querySelector('.play-icon')!;
      this.pauseIcon = this.playPauseBtn.querySelector('.pause-icon')!;
      this.timeDisplay = document.getElementById('modernTime')!;
      this.volumeSlider = document.getElementById('modernVolumeSlider') as HTMLInputElement;
      this.progressRing = document.querySelector('.progress-ring-fill') as SVGCircleElement;
      this.playerContainer = document.querySelector('.modern-player')!;
      this.liveBadge = document.getElementById('modernLiveBadge')!;
      this.timerBtn = document.getElementById('timerBtn')!;
      this.timerModal = document.getElementById('timerModal')!;
      this.timerModalClose = document.getElementById('timerModalClose')!;
      this.timerCancelBtn = document.getElementById('timerCancelBtn')!;
      this.timerBadge = document.getElementById('timerBadge')!;

      // Set initial volume
      this.audio.volume = 0.8;
    }

    initEventListeners() {
      // Play/Pause button
      this.playPauseBtn.addEventListener('click', () => this.togglePlay());

      // Volume slider
      this.volumeSlider.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        this.audio.volume = parseInt(target.value) / 100;
      });

      // Audio events
      this.audio.addEventListener('play', () => this.onPlay());
      this.audio.addEventListener('pause', () => this.onPause());
      this.audio.addEventListener('ended', () => this.onEnded());
      this.audio.addEventListener('error', () => this.onError());

      // Sleep timer
      this.timerBtn.addEventListener('click', () => this.openTimerModal());
      this.timerModalClose.addEventListener('click', () => this.closeTimerModal());
      this.timerCancelBtn.addEventListener('click', () => this.cancelTimer());

      // Timer options
      document.querySelectorAll('.timer-option').forEach(option => {
        option.addEventListener('click', (e) => {
          const minutes = parseInt((e.currentTarget as HTMLElement).dataset.minutes || '0');
          this.startSleepTimer(minutes);
        });
      });

      // Click outside modal to close
      this.timerModal.addEventListener('click', (e) => {
        if (e.target === this.timerModal) {
          this.closeTimerModal();
        }
      });
    }

    initKeyboardShortcuts() {
      document.addEventListener('keydown', (e) => {
        // Space bar for play/pause
        if (e.code === 'Space' && e.target === document.body) {
          e.preventDefault();
          this.togglePlay();
        }
        // Arrow keys for volume
        if (e.code === 'ArrowUp') {
          e.preventDefault();
          this.changeVolume(5);
        }
        if (e.code === 'ArrowDown') {
          e.preventDefault();
          this.changeVolume(-5);
        }
      });
    }

    togglePlay() {
      if (this.isPlaying) {
        this.audio.pause();
      } else {
        this.audio.play();
      }
    }

    onPlay() {
      this.isPlaying = true;
      this.playerContainer.classList.add('playing');
      this.playIcon.style.display = 'none';
      this.pauseIcon.style.display = 'block';
      this.startTimer();
    }

    onPause() {
      this.isPlaying = false;
      this.playerContainer.classList.remove('playing');
      this.playIcon.style.display = 'block';
      this.pauseIcon.style.display = 'none';
      this.stopTimer();
    }

    onEnded() {
      this.onPause();
    }

    onError() {
      console.error('Audio playback error');
      this.onPause();
    }

    startTimer() {
      this.playbackTime = 0;
      if (this.timerInterval) clearInterval(this.timerInterval);

      this.timerInterval = setInterval(() => {
        this.playbackTime++;
        this.updateTimeDisplay();
        this.updateProgressRing();
      }, 1000);
    }

    stopTimer() {
      if (this.timerInterval) {
        clearInterval(this.timerInterval);
        this.timerInterval = null;
      }
    }

    updateTimeDisplay() {
      const minutes = Math.floor(this.playbackTime / 60);
      const seconds = this.playbackTime % 60;
      this.timeDisplay.textContent =
        `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
    }

    updateProgressRing() {
      // Animate progress ring based on time (cycle every 60 seconds)
      const progress = (this.playbackTime % 60) / 60;
      const offset = this.circumference - (progress * this.circumference);
      this.progressRing.style.strokeDashoffset = offset.toString();
    }

    changeVolume(delta: number) {
      const currentVolume = parseInt(this.volumeSlider.value);
      const newVolume = Math.max(0, Math.min(100, currentVolume + delta));
      this.volumeSlider.value = newVolume.toString();
      this.audio.volume = newVolume / 100;
    }

    openTimerModal() {
      this.timerModal.style.display = 'flex';

      // Update cancel button visibility
      if (this.sleepTimer) {
        this.timerCancelBtn.removeAttribute('data-hidden');
      } else {
        this.timerCancelBtn.setAttribute('data-hidden', 'true');
      }
    }

    closeTimerModal() {
      this.timerModal.style.display = 'none';
    }

    startSleepTimer(minutes: number) {
      // Clear any existing timer
      this.cancelTimer();

      // Set new timer
      this.sleepTimerMinutes = minutes;
      this.sleepTimerRemaining = minutes * 60; // Convert to seconds

      // Update UI
      this.timerBtn.setAttribute('data-active', 'true');
      this.updateTimerBadge();
      this.timerBadge.style.display = 'block';

      // Start countdown
      this.sleepTimerCountdown = setInterval(() => {
        this.sleepTimerRemaining--;
        this.updateTimerBadge();

        if (this.sleepTimerRemaining <= 0) {
          this.onTimerExpired();
        }
      }, 1000);

      // Set timeout to stop playback
      this.sleepTimer = setTimeout(() => {
        this.onTimerExpired();
      }, minutes * 60 * 1000);

      // Close modal
      this.closeTimerModal();

      // Show toast notification
      this.showToast(`Timer set for ${minutes} minutes`, 'success');
    }

    cancelTimer() {
      // Clear timers
      if (this.sleepTimer) {
        clearTimeout(this.sleepTimer);
        this.sleepTimer = null;
      }

      if (this.sleepTimerCountdown) {
        clearInterval(this.sleepTimerCountdown);
        this.sleepTimerCountdown = null;
      }

      // Reset state
      this.sleepTimerMinutes = 0;
      this.sleepTimerRemaining = 0;

      // Update UI
      this.timerBtn.removeAttribute('data-active');
      this.timerBadge.style.display = 'none';
      this.closeTimerModal();

      // Show toast notification
      this.showToast('Timer cancelled', 'info');
    }

    updateTimerBadge() {
      const minutes = Math.floor(this.sleepTimerRemaining / 60);
      const seconds = this.sleepTimerRemaining % 60;
      this.timerBadge.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;
    }

    onTimerExpired() {
      // Stop playback
      this.audio.pause();

      // Clear timer
      if (this.sleepTimer) clearTimeout(this.sleepTimer);
      if (this.sleepTimerCountdown) clearInterval(this.sleepTimerCountdown);
      this.sleepTimer = null;
      this.sleepTimerCountdown = null;

      // Reset state
      this.sleepTimerMinutes = 0;
      this.sleepTimerRemaining = 0;

      // Update UI
      this.timerBtn.removeAttribute('data-active');
      this.timerBadge.style.display = 'none';

      // Show toast notification
      this.showToast('Sleep timer expired - playback stopped', 'info');
    }

    showToast(message: string, type: 'success' | 'error' | 'info' = 'info') {
      // Use global showToast if available
      if (typeof (window as any).showToast === 'function') {
        (window as any).showToast(message, type);
      } else {
        // Fallback to console
        console.log(`[${type}] ${message}`);
      }
    }
  }

  // Initialize player when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    new ModernRadioPlayer();
  });
</script>