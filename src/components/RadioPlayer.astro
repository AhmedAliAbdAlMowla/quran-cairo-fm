---
export interface Props {
  lang?: string;
}

const { lang = "ar" } = Astro.props;
const isRTL = lang === "ar";
---

<div class="player-panel glass-panel">
  <!-- Water animation layers -->
  <div class="water-animation">
    <div class="water-wave wave-1"></div>
    <div class="water-wave wave-2"></div>
    <div class="water-wave wave-3"></div>
  </div>

  <div class="player-container">
    <!-- Hidden audio element -->
    <audio id="egyptAudio">
      <source
        src="https://n01.radiojar.com/8s5u5tpdtwzuv?fbclid=IwY2xjawM-dEVleHRuA2FlbQIxMABicmlkETFQTUFDaGlsWG9TT01ucHBqAR679xI89H1GHQfZ56QNibeQAlgM1eFZF1pJGHUj4O7XSqu-1L3AOxdrP4OahA_aem_dhwfAYRQ4N-uewFyHMm0rg&listening-from-radio-garden=1624623936350&rj-ttl=5&rj-tok=AAABmXK3CA0AlLPRdfTei-KzcQ"
        type="audio/mpeg"
      />
      <source
        src="https://n06.radiojar.com/8s5u5tpdtwzuv?rj-ttl=5&rj-tok=AAABmXITLbUAnkhYRNoalMnuuw"
        type="audio/mpeg"
      />
      {isRTL ? "متصفحك لا يدعم عنصر الصوت." : "Your browser does not support the audio element."}
    </audio>

    <!-- Custom counter display -->
    <div class="custom-player">
      <div class="counter-display">
        <div class="counter-label" id="counterLabel">
          {isRTL ? "جاهز" : "Ready"}
        </div>
        <div class="counter-time">
          <span id="currentTime" class="time-digit">00</span>
          <span class="time-separator">:</span>
          <span id="currentSeconds" class="time-digit">00</span>
        </div>
        <div class="live-indicator">
          <span class="live-dot"></span>
          <span class="live-text">{isRTL ? "مباشر" : "Live"}</span>
        </div>
      </div>
    </div>

    <!-- Vertical volume control -->
    <div class="volume-control">
      <div class="volume-icon">🔊</div>
      <div class="volume-slider-container">
        <input
          type="range"
          id="volumeSlider"
          class="volume-slider"
          min="0"
          max="100"
          value="80"
          orient="vertical"
        />
        <div class="volume-fill"></div>
      </div>
      <div class="volume-value">80%</div>
    </div>
  </div>
</div>