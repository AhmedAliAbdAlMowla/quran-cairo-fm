---
import Layout from '../layouts/Layout.astro';
import RadioPlayer from '../components/RadioPlayer.astro';
import ControlButtons from '../components/ControlButtons.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

const title = "Holy Quran Radio from Cairo - Live 24/7 | Quran Online";
const description = "Listen to live broadcast of Holy Quran Radio from Cairo. Recitations around the clock by renowned reciters. Listen to the Holy Quran online for free in high quality.";
const keywords = "Holy Quran, Quran Radio, Live Broadcast, Cairo, Egypt, Recitation, Quran Online, Quran Radio, Listen Quran, Egyptian Reciters, Islamic Radio";
---

<Layout title={title} description={description} keywords={keywords} lang="en" dir="ltr">
  <Fragment slot="head">
    <link rel="alternate" hreflang="ar" href="/" />
    <link rel="alternate" hreflang="en" href="/en" />
    <link rel="alternate" hreflang="x-default" href="/" />
    <link rel="stylesheet" href="/css/style.css" />

    <!-- Structured Data -->
    <script type="application/ld+json" is:inline>
    {
        "@context": "https://schema.org",
        "@type": "RadioStation",
        "name": "Holy Quran Radio from Cairo",
        "alternateName": "Egypt Quran Radio",
        "url": "https://qurancairofm.com/en",
        "logo": "https://qurancairofm.com/images/mosque.png",
        "description": "Holy Quran Radio from Cairo - 24/7 live broadcast of the Holy Quran",
        "address": {
            "@type": "PostalAddress",
            "addressLocality": "Cairo",
            "addressCountry": "EG"
        },
        "geo": {
            "@type": "GeoCoordinates",
            "latitude": 30.0444,
            "longitude": 31.2357
        },
        "areaServed": {
            "@type": "GeoShape",
            "name": "Worldwide"
        },
        "inLanguage": ["ar", "en"],
        "broadcastFrequency": "Online",
        "potentialAction": {
            "@type": "ListenAction",
            "target": {
                "@type": "EntryPoint",
                "urlTemplate": "https://qurancairofm.com/en",
                "actionPlatform": [
                    "http://schema.org/DesktopWebPlatform",
                    "http://schema.org/MobileWebPlatform",
                    "http://schema.org/IOSPlatform",
                    "http://schema.org/AndroidPlatform"
                ]
            },
            "expectsAcceptanceOf": {
                "@type": "Offer",
                "price": "0",
                "priceCurrency": "USD",
                "eligibleRegion": {
                    "@type": "Place",
                    "name": "Worldwide"
                }
            }
        }
    }
    </script>
  </Fragment>

  <!-- Language Switcher -->
  <LanguageSwitcher currentLang="en" />

  <!-- Animated background gradient -->
  <div class="background-gradient">
    <div class="gradient-orb orb-1"></div>
    <div class="gradient-orb orb-2"></div>
    <div class="gradient-orb orb-3"></div>
  </div>

  <!-- Main container with glass effect -->
  <div class="glass-container">
    <!-- Header glass panel -->
    <div class="glass-panel header-panel">
      <div class="water-ripple"></div>
      <h1 class="glass-title">
        <img src="/images/mosque.png" alt="Islamic Icon" class="icon-glow" style="width: 2.5em; height: 2.5em; vertical-align: middle;">
        <span class="title-text">Holy Quran Radio</span>
      </h1>
      <p class="subtitle">From Cairo • Egypt</p>
    </div>

    <!-- Player glass panel -->
    <RadioPlayer lang="en" />

    <!-- Controls glass panel -->
    <ControlButtons lang="en" />

    <!-- Status glass panel -->
    <div class="glass-panel status-panel">
      <div class="status-indicator">
        <span class="pulse-dot"></span>
        <span id="status" class="status-text">Ready to Play</span>
      </div>
    </div>
  </div>

  <!-- Floating particles effect -->
  <div class="particles-container">
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
  </div>

  <!-- Developer Credit -->
  <div class="dev-credit">
    <a href="https://engahmedali.dev/" target="_blank" rel="noopener" class="dev-link">
      <span class="dev-text">Ahmed Ali</span>
    </a>
  </div>

  <script src="/js/script.js" is:inline></script>
</Layout>